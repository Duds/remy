# ── Required ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Telegram ──────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
TELEGRAM_ALLOWED_USERS_RAW=123456789

# ── Model routing ─────────────────────────────────────────────────────────────
MODEL_SIMPLE=claude-haiku-4-5-20251001
MODEL_COMPLEX=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=4096

# ── Ollama fallback ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FALLBACK_MODEL=llama3:latest
OLLAMA_TIMEOUT=120.0

# ── Environment ───────────────────────────────────────────────────────────────
# Set to true when running in Azure Container Instances
AZURE_ENVIRONMENT=false
# Override data directory (default: ./data locally, /data in Azure)
# DATA_DIR=./data

# ── Git tools (US-git-commits-and-diffs) ───────────────────────────────────────
# Leave empty to use current working directory. Set when git_log/git_diff/etc.
# must target a specific repo (e.g. in Docker, where /app has no .git).
# Docker with compose: docker-compose sets WORKSPACE_ROOT for you.
# Override here if your remy repo is elsewhere (path as seen inside container).
# WORKSPACE_ROOT=/home/remy/Projects/ai-agents/remy
WORKSPACE_ROOT=

# ── Scheduler ─────────────────────────────────────────────────────────────────
BRIEFING_CRON=0 7 * * *
CHECKIN_CRON=0 19 * * *
SCHEDULER_TIMEZONE=Australia/Sydney

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Prevents rate limiting on unauthenticated HF Hub requests (embeddings).
# Get a free read token at https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Health API ────────────────────────────────────────────────────────────────
# Token required for /logs and /telemetry endpoints (leave empty = no auth)
# Usage: curl -H "Authorization: Bearer <token>" https://remy.yourdomain.com/logs
HEALTH_API_TOKEN=

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Exposes health server (port 8080) publicly over HTTPS via Cloudflare Tunnel.
# Get token: dash.cloudflare.com → Zero Trust → Networks → Tunnels → Create tunnel
# Start tunnel: make tunnel-up   (runs cloudflared as a Docker service)
CLOUDFLARE_TUNNEL_TOKEN=

# ── SOUL.md path ──────────────────────────────────────────────────────────────
SOUL_MD_PATH=config/SOUL.md

# ── Azure webhook (only needed for webhook mode in ACI) ───────────────────────
# WEBHOOK_URL=https://your-domain.com/webhook
# PORT=8443

# ── Relay (Claude Desktop ↔ Remy, US-relay-shared-backend) ───────────────────
# URL of the relay MCP server (if Remy talks to relay over HTTP). Leave empty to use shared SQLite.
# RELAY_MCP_URL=http://localhost:8765
RELAY_MCP_URL=
# Shared secret for relay API auth (required if RELAY_MCP_URL is set)
RELAY_MCP_SECRET=
# Path to relay SQLite DB. Leave empty to use data_dir/relay.db (same as make relay-run).
# Set if the shared relay server uses a different path (e.g. when run elsewhere).
# RELAY_DB_PATH=/path/to/relay.db
RELAY_DB_PATH=
