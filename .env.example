# ── Required ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Telegram ──────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
TELEGRAM_ALLOWED_USERS_RAW=123456789

# ── Model routing ─────────────────────────────────────────────────────────────
MODEL_SIMPLE=claude-haiku-4-5-20251001
MODEL_COMPLEX=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=4096

# ── Ollama fallback ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FALLBACK_MODEL=llama3:latest
OLLAMA_TIMEOUT=120.0

# ── Environment ───────────────────────────────────────────────────────────────
# Set to true when running in Azure Container Instances
AZURE_ENVIRONMENT=false
# Override data directory (default: ./data locally, /data in Azure)
# DATA_DIR=./data

# ── Git tools (US-git-commits-and-diffs) ───────────────────────────────────────
# Leave empty to use current working directory. Set when git_log/git_diff/etc.
# must target a specific repo (e.g. in Docker, where /app has no .git).
# Docker with compose: docker-compose sets WORKSPACE_ROOT for you.
# Override here if your remy repo is elsewhere (path as seen inside container).
# WORKSPACE_ROOT=/home/remy/Projects/ai-agents/remy
WORKSPACE_ROOT=

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Evaluative heartbeat (SAD v7): when true, single 30-min job replaces fixed briefing/check-in crons.
# When false, legacy crons run (BRIEFING_CRON, CHECKIN_CRON, AFTERNOON_CHECK_CRON).
HEARTBEAT_ENABLED=true
# Heartbeat job schedule (default: every 30 min). Quiet hours: no evaluation between 22:00 and 07:00 local.
# HEARTBEAT_CRON=*/30 * * * *
# HEARTBEAT_QUIET_START=22
# HEARTBEAT_QUIET_END=7
# Path to HEARTBEAT.md (gitignored; fallback: HEARTBEAT.example.md). Model for evaluation:
# HEARTBEAT_MD_PATH=config/HEARTBEAT.md
# HEARTBEAT_MODEL_TIER2=claude-sonnet-4-20250514
# Daily orientation / wellbeing (used by HEARTBEAT.md logic): wake hour, reflection hour, wellbeing window
# ORIENTATION_WAKE_HOUR=7
# REFLECTION_HOUR=18
# WELLBEING_WINDOW_START=13
# WELLBEING_WINDOW_END=19

BRIEFING_CRON=0 7 * * *
CHECKIN_CRON=0 19 * * *
# Legacy afternoon check (only when HEARTBEAT_ENABLED=false): mediated, compassionate check-in (default 17:00).
# AFTERNOON_CHECK_CRON=0 17 * * *
SCHEDULER_TIMEZONE=Australia/Sydney
# Morning briefing email scope: inbox_only | primary_tabs | all_mail (US-gmail-check-all-mail).
# Heartbeat always uses all mail for unread count.
# BRIEFING_EMAIL_SCOPE=inbox_only
BRIEFING_EMAIL_SCOPE=all_mail

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Prevents rate limiting on unauthenticated HF Hub requests (embeddings).
# Get a free read token at https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Health API ────────────────────────────────────────────────────────────────
# Token required for /logs and /telemetry endpoints (leave empty = no auth)
# Usage: curl -H "Authorization: Bearer <token>" https://remy.yourdomain.com/logs
HEALTH_API_TOKEN=

# ── File download links (US-mac-file-links-secure-download) ───────────────────
# Public base URL for secure file links (e.g. https://remy.dalerogers.com.au). Empty = disabled.
# When set, Remy can generate short-lived download links for files in ~/Projects, ~/Documents, ~/Downloads.
FILE_LINK_BASE_URL=
# Optional: secret for signing file-link tokens. Empty = use HEALTH_API_TOKEN.
# FILE_LINK_SECRET=
# Link validity in minutes (default 15, max 60).
# FILE_LINK_EXPIRY_MINUTES=15

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Exposes health server (port 8080) publicly over HTTPS via Cloudflare Tunnel.
# Get token: dash.cloudflare.com → Zero Trust → Networks → Tunnels → Create tunnel
# Start tunnel: make tunnel-up   (runs cloudflared as a Docker service)
CLOUDFLARE_TUNNEL_TOKEN=

# ── Claude Desktop / Claude Code CLI ─────────────────────────────────────────
# When true, tool routing can prefer the Claude Code CLI (subscription) over API for eligible requests.
# CLAUDE_DESKTOP_ENABLED=false
# CLAUDE_DESKTOP_CLI_PATH=claude

# ── Session compaction (SAD v7) ───────────────────────────────────────────────
# Trigger compaction when session exceeds this many tokens (default 40000) or turn count.
# COMPACTION_TOKEN_THRESHOLD=40000
# COMPACTION_TURN_THRESHOLD=80
# COMPACTION_KEEP_RECENT_MESSAGES=20

# ── SOUL.md path ──────────────────────────────────────────────────────────────
SOUL_MD_PATH=config/SOUL.md
# SOUL_COMPACT_PATH=config/SOUL.compact.md
# SOUL_PREFER_COMPACT=true

# ── Azure webhook (only needed for webhook mode in ACI) ───────────────────────
# WEBHOOK_URL=https://your-domain.com/webhook
# PORT=8443

# ── Sub-agent orchestration (SAD v10 §11) ────────────────────────────────────
# SUBAGENT_MAX_WORKERS=5
# SUBAGENT_MAX_DEPTH=2
# SUBAGENT_MAX_CHILDREN=3
# SUBAGENT_STALL_MINUTES=30
# SUBAGENT_WORKER_MODEL=mistral
# SUBAGENT_SYNTH_MODEL=claude-sonnet-4-20250514
# TASK_MD_PATH=config/TASK.md

# ── Relay (Claude Desktop ↔ Remy, US-relay-shared-backend) ───────────────────
# URL of the relay MCP server (if Remy talks to relay over HTTP). Leave empty to use shared SQLite.
# RELAY_MCP_URL=http://localhost:8765
RELAY_MCP_URL=
# Shared secret for relay API auth (required if RELAY_MCP_URL is set)
RELAY_MCP_SECRET=
# Path to relay SQLite DB. Leave empty to use data_dir/relay.db (same as make relay-run).
# Set if the shared relay server uses a different path (e.g. when run elsewhere).
# RELAY_DB_PATH=/path/to/relay.db
RELAY_DB_PATH=

# ── File index / Google Drive (US-google-drive-rag-indexing) ───────────────────
# Comma-separated paths to locally mounted Google Drive to index and search.
# If a path does not exist at startup (e.g. Drive not mounted), a warning is logged and Remy continues.
# macOS (Google Drive for Desktop): ~/Library/CloudStorage/GoogleDrive-<your-email>
# Or index only "My Drive": add "/My Drive" to the path above.
# GDRIVE_MOUNT_PATHS=~/Library/CloudStorage/GoogleDrive-<your-email>
GDRIVE_MOUNT_PATHS=

# Docker only: host path to Google Drive to mount into the container. Leave empty to skip (empty dir mounted).
# When set, use GDRIVE_MOUNT_PATHS=/home/remy/GoogleDrive in .env so Remy finds the files.
# GDRIVE_MOUNT_PATH=~/Library/CloudStorage/GoogleDrive-<your-email>
GDRIVE_MOUNT_PATH=

# ── RAG PDF/DOCX and OCR (US-rag-pdf-docx) ────────────────────────────────────
# Set to false to index only text-extractable PDFs (no OCR for scanned/image PDFs).
# RAG_PDF_OCR_ENABLED=true
# Tesseract language(s), e.g. eng or eng+fra. Requires Tesseract installed (e.g. brew install tesseract).
# RAG_OCR_LANG=eng
