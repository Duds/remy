    class OC_MEM,OC_SOUL,OC_UMEM,OC_DAILY,OC_HIST oc_mem
    class OC_MDL,OC_CHEAP,OC_FRONT oc_mdl
    class RY_BOT,RY_POLL,RY_SESS,RY_STRM ry_bot
    class RY_AI,RY_ROUTE,RY_CLAUDE,RY_TOOLS ry_ai
    class RY_MEM,RY_GOALS,RY_FACTS,RY_CONV,RY_VEC ry_mem
    class RY_INT,RY_GMAIL,RY_CAL,RY_CONT,RY_WEB,RY_FILE,RY_GDOC ry_int
