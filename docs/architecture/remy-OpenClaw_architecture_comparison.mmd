flowchart TB
    subgraph OC["OPENCLAW — Platform / Infrastructure"]
        direction TB

        subgraph OC_IN["Inputs"]
            OC_WA([WhatsApp]) & OC_TG([Telegram]) & OC_SL([Slack]) & OC_WH([Webhook])
            OC_HB([Heartbeat 30min]) & OC_CR([Cron Jobs])
        end

        subgraph OC_GW["Gateway — Control Plane (WebSocket RPC)"]
            OC_CA[Channel Adapter] --> OC_CTX[Context Assembly\nSOUL.md · MEMORY.md · Tools]
            OC_CTX --> OC_LQ[Lane Queue\nSerial by default]
        end

        subgraph OC_RT["Agent Runtime — Pi SDK Embedded"]
            OC_REACT["ReAct Loop\nReason → Tool → Observe → Repeat"]
            OC_TOOLS["Tool Layer\nExec · File · Browser · Web"]
            OC_SKILLS["Skills\nSKILL.md on demand"]
        end

        subgraph OC_SUB["Sub-Agent Layer"]
            OC_D0[Main Agent\nDepth 0]
            OC_D1A[Orchestrator\nDepth 1] & OC_D1B[Worker\nDepth 1]
            OC_D2A[Leaf\nDepth 2] & OC_D2B[Leaf\nDepth 2]
        end

        subgraph OC_MEM["Memory — File Based"]
            OC_SOUL[SOUL.md] & OC_UMEM[MEMORY.md] & OC_DAILY[Daily Notes] & OC_HIST[Sessions JSON]
        end

        subgraph OC_MDL["Model Routing"]
            OC_CHEAP[Cheap Model\nHeartbeat · Sub-agents]
            OC_FRONT[Frontier Model\nMain Orchestrator]
        end

        OC_IN --> OC_GW
        OC_LQ --> OC_D0
        OC_D0 --> OC_RT
        OC_D0 -->|sessions_spawn| OC_D1A & OC_D1B
        OC_D1A -->|sessions_spawn| OC_D2A & OC_D2B
        OC_D2A & OC_D2B -->|announce| OC_D1A
        OC_D1A & OC_D1B -->|announce| OC_D0
        OC_MEM --> OC_CTX
        OC_D0 --> OC_FRONT
        OC_D1A & OC_D1B --> OC_CHEAP
    end

    subgraph RY["REMY — Personal Agent / Application"]
        direction TB

        subgraph RY_IN["Inputs"]
            RY_TG([Telegram\nSingle Channel])
            RY_CR([Cron\nBriefing · Check-in · Alcohol])
        end

        subgraph RY_BOT["Bot Layer"]
            RY_POLL[Polling Handler]
            RY_SESS[Session Manager\nJSONL transcripts]
            RY_STRM[Streaming Handler]
        end

        subgraph RY_AI["AI Layer"]
            RY_ROUTE[Message Router\nSimple vs Complex]
            RY_CLAUDE[Claude Client\nStreaming + Tools]
            RY_TOOLS[Tool Registry\n50+ tools]
        end

        subgraph RY_MEM["Memory Layer — SQLite"]
            RY_GOALS[Goals & Plans]
            RY_FACTS[Facts Store]
            RY_CONV[Conversations]
            RY_VEC[sqlite-vec\nEmbeddings]
        end

        subgraph RY_INT["Integration Layer"]
            RY_GMAIL[Gmail] & RY_CAL[Calendar] & RY_CONT[Contacts]
            RY_WEB[Web Search] & RY_FILE[File System] & RY_GDOC[GDocs]
        end

        subgraph RY_INFRA["Infrastructure"]
            RY_HLTH[Health Server\n/health · /metrics · /logs]
            RY_DIAG[Self-Diagnostics]
            RY_RELAY[Relay MCP\nClaude Code Bridge]
            RY_CONF[Config + .env]
        end

        subgraph RY_MDL["Model Routing"]
            RY_SIMPLE[Haiku\nSimple Tasks]
            RY_COMPLEX[Sonnet\nComplex Tasks]
        end

        RY_IN --> RY_POLL
        RY_POLL --> RY_SESS --> RY_ROUTE
        RY_ROUTE --> RY_CLAUDE
        RY_CLAUDE --> RY_TOOLS
        RY_TOOLS --> RY_INT
        RY_TOOLS --> RY_MEM
        RY_CLAUDE --> RY_STRM
        RY_ROUTE --> RY_SIMPLE & RY_COMPLEX
        RY_INFRA --> RY_RELAY
    end

    RY_STRM -->|response| RY_TG
    OC_D0 -->|stream| OC_TG

