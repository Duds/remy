    classDef ry_ai fill:#1a2a3a,stroke:#60a5fa,color:#eff6ff
    classDef ry_mem fill:#1a3a2a,stroke:#86efac,color:#f0fdf4
    classDef ry_int fill:#3a3a1a,stroke:#fbbf24,color:#fffbeb
    classDef ry_inf fill:#2a2a2a,stroke:#9ca3af,color:#f9fafb
