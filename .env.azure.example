# Azure deployment variables for Remy (make deploy / make deploy-update)
# Copy to .env.azure and fill in values when you're ready to deploy.
# Do not commit .env.azure (it contains secrets).
#
# Discover values using Azure CLI (run in your terminal after: az login):
#
# ACR_NAME — Azure Container Registry name (lowercase, no spaces)
#   az acr list --query "[].name" -o tsv
#   If none exists: az acr create --name <unique-name> --resource-group <RG> --sku Basic
#
# RESOURCE_GROUP — Resource group for the container and (optionally) ACR/storage
#   az group list --query "[].name" -o tsv
#   Or create: az group create --name remy-rg --location australiaeast
#
# STORAGE_ACCOUNT — Storage account for Azure Files (SQLite persistence)
#   az storage account list --query "[].name" -o tsv
#   If none: az storage account create --name <unique-name> --resource-group <RG> --location australiaeast
#
# STORAGE_KEY — Storage account key (keep secret)
#   az storage account keys list --account-name <STORAGE_ACCOUNT> --resource-group <RG> --query "[0].value" -o tsv
#
# STORAGE_SHARE — Azure Files share name (e.g. remy-data)
#   az storage share list --account-name <STORAGE_ACCOUNT> --account-key <STORAGE_KEY> --query "[].name" -o tsv
#   If none: az storage share create --name remy-data --account-name <STORAGE_ACCOUNT> --account-key <STORAGE_KEY>
#
# TELEGRAM_BOT_TOKEN, ANTHROPIC_API_KEY — Same as local .env (or reuse from there).
#   Set here so the container gets them via --secure-environment-variables.

ACR_NAME=
RESOURCE_GROUP=
STORAGE_ACCOUNT=
STORAGE_KEY=
STORAGE_SHARE=remy-data
TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=
